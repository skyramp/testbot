{
  "name": "skyramp-testbot",
  "version": "0.1.0",
  "description": "Github Action for using Skyramp's Testbot for AI-Powered Deterministic Testing",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --outfile=dist/index.js --sourcemap --format=cjs && esbuild src/post.ts --bundle --platform=node --target=node24 --outfile=dist/post.js --sourcemap --format=cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "package": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/letsramp/testbot"
  },
  "author": "Skyramp Inc",
  "license": "MIT",
  "dependencies": {
    "@actions/artifact": "^6.1.0",
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@actions/io": "^3.0.2",
    "@skyramp/skyramp": "^1.3.15"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
